---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Thabo Sibanda — open to cybersecurity roles, collaborations, and professional conversations."
>

<header style="
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-default);
  padding: var(--space-16) 0 var(--space-10);
">
  <div class="container" style="max-width: 720px;">
    <div style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent-primary); margin-bottom: var(--space-4);">// contact/</div>
    <h1 style="margin-bottom: var(--space-4);">Get in Touch</h1>
    <p style="font-size: var(--text-lg); color: var(--text-secondary); max-width: 52ch; line-height: 1.6;">
      Open to cybersecurity roles, red team collaborations, CTF teams,
      and professional conversations. Response time: typically within 48 hours.
    </p>
  </div>
</header>

<section style="padding: var(--space-16) 0;">
  <div class="container" style="max-width: 720px; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-10); align-items: start;" class="contact-grid">

    <!-- Left: links -->
    <div>
      <div style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent-primary); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: var(--space-6);">// find_me_at</div>

      <div style="display: flex; flex-direction: column; gap: var(--space-3);">
        {[
          { label: 'LinkedIn',   href: 'https://www.linkedin.com/in/thabo-sibanda-68284839b/',  icon: '💼', note: 'Primary professional channel' },
          { label: 'GitHub',     href: 'https://github.com/thabo-spec/thabosibanda.dev',       icon: '🐙', note: 'Code, scripts & lab notes' },
          { label: 'TryHackMe',  href: 'https://tryhackme.com/p/thabosibanda152',  icon: '🎯', note: 'Learning path & badges' },
          { label: 'HackTheBox', href: 'https://profile.hackthebox.com/profile/019e3f6f-6dea-71e2-b173-a1cdee0e189b', icon: '📦', note: 'Machine write-ups' },
        ].map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card"
            style="text-decoration: none; display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4);"
          >
            <span style="font-size: 22px; flex-shrink: 0;">{link.icon}</span>
            <div>
              <div style="font-weight: 500; color: var(--text-primary); margin-bottom: 2px;">{link.label}</div>
              <div style="font-size: var(--text-sm); color: var(--text-muted);">{link.note}</div>
            </div>
            <span style="margin-left: auto; color: var(--accent-secondary); font-size: var(--text-lg);">→</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: contact form (Netlify/Formspree-ready) -->
    <div>
      <div style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent-primary); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: var(--space-6);">// send_message</div>

      <!--
        To wire this form up:
        Option A — Formspree: set action="https://formspree.io/f/YOUR_ID" method="POST"
        Option B — Netlify:   add netlify attribute to the form tag
        Option C — Vercel:    use a Vercel serverless function at /api/contact.js
      -->
      <form
        action="https://formspree.io/f/YOUR_FORMSPREE_ID"
        method="POST"
        style="display: flex; flex-direction: column; gap: var(--space-4);"
      >
        <div>
          <label for="name" style="display: block; font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-2); font-family: var(--font-mono);">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your name"
            style="
              width: 100%;
              padding: var(--space-3) var(--space-4);
              background: var(--bg-surface);
              border: 1px solid var(--border-default);
              border-radius: var(--radius-md);
              color: var(--text-primary);
              font-family: var(--font-body);
              font-size: var(--text-sm);
              outline: none;
              transition: border-color 0.2s ease;
            "
            onfocus="this.style.borderColor='var(--accent-primary)'"
            onblur="this.style.borderColor='var(--border-default)'"
          />
        </div>

        <div>
          <label for="email" style="display: block; font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-2); font-family: var(--font-mono);">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@company.com"
            style="
              width: 100%;
              padding: var(--space-3) var(--space-4);
              background: var(--bg-surface);
              border: 1px solid var(--border-default);
              border-radius: var(--radius-md);
              color: var(--text-primary);
              font-family: var(--font-body);
              font-size: var(--text-sm);
              outline: none;
              transition: border-color 0.2s ease;
            "
            onfocus="this.style.borderColor='var(--accent-primary)'"
            onblur="this.style.borderColor='var(--border-default)'"
          />
        </div>

        <div>
          <label for="subject" style="display: block; font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-2); font-family: var(--font-mono);">Subject</label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            placeholder="Role enquiry / Collaboration / Other"
            style="
              width: 100%;
              padding: var(--space-3) var(--space-4);
              background: var(--bg-surface);
              border: 1px solid var(--border-default);
              border-radius: var(--radius-md);
              color: var(--text-primary);
              font-family: var(--font-body);
              font-size: var(--text-sm);
              outline: none;
              transition: border-color 0.2s ease;
            "
            onfocus="this.style.borderColor='var(--accent-primary)'"
            onblur="this.style.borderColor='var(--border-default)'"
          />
        </div>

        <div>
          <label for="message" style="display: block; font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-2); font-family: var(--font-mono);">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell me about the opportunity or what you'd like to discuss..."
            style="
              width: 100%;
              padding: var(--space-3) var(--space-4);
              background: var(--bg-surface);
              border: 1px solid var(--border-default);
              border-radius: var(--radius-md);
              color: var(--text-primary);
              font-family: var(--font-body);
              font-size: var(--text-sm);
              outline: none;
              resize: vertical;
              min-height: 120px;
              transition: border-color 0.2s ease;
            "
            onfocus="this.style.borderColor='var(--accent-primary)'"
            onblur="this.style.borderColor='var(--border-default)'"
          ></textarea>
        </div>

        <button
          type="submit"
          class="btn btn--primary"
          style="align-self: flex-start; font-size: var(--text-base); padding: 0.75em 2em;"
        >
          Send Message →
        </button>
      </form>
    </div>

  </div>
</section>

<style>
  @media (max-width: 640px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

</BaseLayout>
