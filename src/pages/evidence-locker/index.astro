---
// src/pages/evidence-locker/index.astro
// Lists all project write-ups from src/content/projects/
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Load all project entries (exclude the template file)
const allProjects = await getCollection('projects', ({ id }: { id: string }) => {
  return !id.startsWith('_');
});

// Sort: featured first, then by date descending
const sorted = allProjects.sort((a: any, b: any) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

function severityClass(score: number): string {
  if (score >= 9.0) return 'badge--critical';
  if (score >= 7.0) return 'badge--high';
  if (score >= 4.0) return 'badge--medium';
  return 'badge--low';
}

function severityLabel(score: number): string {
  if (score >= 9.0) return 'Critical';
  if (score >= 7.0) return 'High';
  if (score >= 4.0) return 'Medium';
  return 'Low';
}
---

<BaseLayout
  title="Evidence Locker"
  description="Thabo Sibanda's documented security work — penetration testing write-ups, lab reports, and home lab case studies."
>
  <!-- Page header -->
  <header style="
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-default);
    padding: var(--space-16) 0 var(--space-12);
  ">
    <div class="container">
      <div style="
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--accent-primary);
        margin-bottom: var(--space-4);
      ">// evidence_locker/</div>
      <h1 style="margin-bottom: var(--space-4);">Evidence Locker</h1>
      <p style="max-width: 60ch; font-size: var(--text-lg);">
        Structured write-ups of security labs, HackTheBox machines, TryHackMe rooms,
        and home lab investigations. Every entry documents the challenge, methodology,
        findings, and real-world business impact.
      </p>
    </div>
  </header>

  <!-- Project grid -->
  <section class="section">
    <div class="container">

      {sorted.length === 0 ? (
        <!-- Empty state -->
        <div class="terminal" style="max-width: 600px; margin: 0 auto;">
          <div class="terminal__header">
            <span class="terminal__dot terminal__dot--red"></span>
            <span class="terminal__dot terminal__dot--amber"></span>
            <span class="terminal__dot terminal__dot--green"></span>
            <span class="terminal__title">evidence-locker ~ bash</span>
          </div>
          <div class="terminal__body">
            <p>
              <span class="terminal__prompt">thabo@portfolio:~$ </span>
              ls evidence-locker/
            </p>
            <p style="color: var(--accent-warning); margin-top: var(--space-3);">
              # No entries yet. Copy src/content/projects/_template.md<br />
              # to add your first write-up.
            </p>
          </div>
        </div>
      ) : (
        <div style="display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));">
          {sorted.map((project: any) => (
            <a
              href={`/evidence-locker/${project.slug}`}
              style="text-decoration: none;"
            >
              <article class={`card ${project.data.featured ? 'card--featured' : ''}`} style="height: 100%; display: flex; flex-direction: column;">

                <!-- Card header -->
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-4); gap: var(--space-3);">
                  <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                    <span class="badge badge--platform">{project.data.platform}</span>
                    <span class="badge badge--platform">{project.data.difficulty}</span>
                  </div>
                  {project.data.cvss_score && (
                    <span class={`badge ${severityClass(project.data.cvss_score)}`} style="white-space: nowrap;">
                      {project.data.cvss_score} {severityLabel(project.data.cvss_score)}
                    </span>
                  )}
                </div>

                <!-- Title -->
                <h2 style="font-size: var(--text-xl); margin-bottom: var(--space-3); flex: 1;">
                  {project.data.title}
                </h2>

                <!-- Category tags -->
                {project.data.category && (
                  <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4);">
                    {project.data.category.map((cat: string) => (
                      <span style="
                        font-size: var(--text-xs);
                        font-family: var(--font-mono);
                        padding: 0.2em 0.6em;
                        border-radius: 4px;
                        background: rgba(0,212,170,0.08);
                        color: var(--color-mint-300);
                        border: 1px solid rgba(0,212,170,0.15);
                      ">{cat}</span>
                    ))}
                  </div>
                )}

                <!-- Footer -->
                <div style="
                  display: flex;
                  justify-content: space-between;
                  align-items: center;
                  padding-top: var(--space-4);
                  border-top: 1px solid var(--border-subtle);
                  margin-top: auto;
                  font-size: var(--text-sm);
                  color: var(--text-muted);
                  font-family: var(--font-mono);
                ">
                  <span>{new Date(project.data.date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                  <span style="color: var(--accent-secondary);">Read write-up →</span>
                </div>
              </article>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
