---
// src/pages/index.astro — Home / Mission page
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Thabo Sibanda — Cybersecurity Professional. From Attack Surface to Zero Risk."
>

  <!-- Hero ─────────────────────────────────────────────────────── -->
  <section
    class="section bg-grid"
    style="
      background-color: var(--bg-primary);
      background-image:
        linear-gradient(rgba(74,158,202,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(74,158,202,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
      position: relative;
    "
  >
    <!-- Radial glow -->
    <div style="
      position: absolute; top: 0; right: 0;
      width: 600px; height: 600px;
      background: radial-gradient(circle at 70% 30%, rgba(0,212,170,0.06) 0%, transparent 65%);
      pointer-events: none;
    "></div>

    <div class="container" style="max-width: 900px; position: relative;">

      <!-- Eyebrow -->
      <div style="
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--accent-primary);
        margin-bottom: var(--space-6);
        display: flex; align-items: center; gap: var(--space-3);
      ">
        <span style="display:inline-block; width:32px; height:1px; background: var(--accent-primary);"></span>
        Thabo Sibanda &mdash; Cybersecurity Professional
      </div>

      <!-- Headline -->
      <h1 style="
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin-bottom: var(--space-6);
        max-width: 16ch;
      ">
        From <span style="color: var(--accent-secondary);">Attack Surface</span><br />
        to <span style="color: var(--accent-primary);">Zero Risk.</span>
      </h1>

      <!-- Subheading -->
      <p style="
        font-size: var(--text-xl);
        color: var(--text-muted);
        max-width: 56ch;
        margin-bottom: var(--space-10);
        line-height: 1.6;
      ">
        I find what's broken before adversaries do. Analytical, methodical, and fluent
        in translating complex vulnerabilities into clear, actionable security decisions
        for technical teams and business stakeholders alike.
      </p>

      <!-- CTAs -->
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-4);">
        <a href="/evidence-locker" class="btn btn--primary" style="font-size: var(--text-base); padding: 0.8em 1.8em;">
          View Evidence Locker →
        </a>
        <a href="/about" class="btn btn--outline" style="font-size: var(--text-base); padding: 0.8em 1.8em;">
          About Thabo
        </a>
      </div>

      <!-- Quick stats -->
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: var(--space-6);
        margin-top: var(--space-16);
        padding-top: var(--space-12);
        border-top: 1px solid var(--border-default);
        max-width: 640px;
      ">
        {[
          { value: '20+', label: 'Labs Documented' },
          { value: 'CVSS', label: 'Risk-Scored Findings' },
          { value: '5+', label: 'Attack Domains' },
        ].map(stat => (
          <div>
            <div style="font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: 800; color: var(--accent-primary); margin-bottom: var(--space-1);">
              {stat.value}
            </div>
            <div style="font-size: var(--text-sm); color: var(--text-muted);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Evidence Locker Preview ───────────────────────────────────── -->
  <section class="section" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">// evidence_locker/</span>
        <h2 class="section-heading__title">Documented Security Work</h2>
        <p class="section-heading__subtitle">
          Every entry follows a structured forensic format — challenge scoping,
          tool selection rationale, methodology, and findings translated into
          business impact. This is what professional security work looks like.
        </p>
      </div>

      <!-- Evidence Locker philosophy callout -->
      <div class="card card--featured" style="max-width: 640px; margin-bottom: var(--space-8);">
        <div style="
          font-family: var(--font-mono);
          font-size: var(--text-xs);
          color: var(--accent-primary);
          margin-bottom: var(--space-3);
          text-transform: uppercase;
          letter-spacing: 0.12em;
        ">The Evidence Locker Philosophy</div>
        <p style="margin-bottom: 0; font-size: var(--text-base); color: var(--text-secondary);">
          In security, assertions without evidence are just noise. Every project here
          documents the <em>what</em>, the <em>how</em>, and the <em>why it matters</em>
          — from the initial attack surface to the remediation recommendation.
        </p>
      </div>

      <a href="/evidence-locker" class="btn btn--outline">
        Open the Evidence Locker →
      </a>
    </div>
  </section>

</BaseLayout>
